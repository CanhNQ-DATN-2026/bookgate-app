# api-service environment variables
# In production these are sourced from the bookgate-secret Kubernetes Secret
# (pre-synced from AWS Secrets Manager). This file is for reference only.

DATABASE_URL=postgresql://bookgate:CHANGE_ME@rds-endpoint:5432/bookgate
SECRET_KEY=CHANGE_ME_32_chars_minimum
ADMIN_PASSWORD=CHANGE_ME

S3_BUCKET_NAME=bookgate-prod
AWS_DEFAULT_REGION=ap-southeast-1

ADMIN_EMAIL=admin@bookgate.com
ADMIN_FULL_NAME=System Admin
CORS_ORIGINS=https://bookgate.example.com
